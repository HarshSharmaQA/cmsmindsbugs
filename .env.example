# ──────────────────────────────────────────────────────────────────────────────
# BugScribe Environment Variables — EXAMPLE FILE
# Copy this file to .env.local and fill in your real values.
# ⚠️  NEVER commit .env.local or put real secrets in this file.
# ──────────────────────────────────────────────────────────────────────────────

# Convex Deployment (run: npx convex dev to get these)
CONVEX_DEPLOYMENT=dev:your-deployment-slug

NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Clerk Authentication Keys (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-subdomain.clerk.accounts.dev

# Resend Email Integration (get from https://resend.com/api-keys)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# Admin Accounts (comma-separated list of super admin emails)
SUPER_ADMIN_EMAILS=admin@yourdomain.com
