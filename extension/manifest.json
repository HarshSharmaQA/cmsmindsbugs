{
    "manifest_version": 3,
    "name": "BugScribe Reporter",
    "version": "2.0",
    "description": "Capture bugs naturally. Standalone reporter that takes screenshots and posts to BugScribe.",
    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "scripting",
        "unlimitedStorage",
        "captureVisibleTab"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "https://bugscripe.vercel.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "popup.html",
                "popup.js",
                "images/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}